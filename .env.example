# GCP Configuration
PROJECT_ID=your-project-id
PROJECT_NUMBER=your-project-number
GOOGLE_CLOUD_LOCATION=us-central1

# Deployed Agent IDs (update these after deployment)
COCKTAIL_AGENT_ID=your-cocktail-agent-id
WEATHER_AGENT_ID=your-weather-agent-id
HOSTING_AGENT_ID=your-hosting-agent-id

# MCP Server URLs
CT_MCP_SERVER_URL=https://your-cocktail-mcp-url/mcp/
WEA_MCP_SERVER_URL=https://your-weather-mcp-url/mcp/

# Service Account
APP_SERVICE_ACCOUNT=your-service-account@your-project.iam.gserviceaccount.com

# Deployment Configuration
DISPLAY_NAME_SUFFIX=Staging
BUCKET_NAME=your-bucket-name
REQUIREMENTS_FILE=requirements.txt
