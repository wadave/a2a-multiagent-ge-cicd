# Copy this file to terraform.tfvars and fill in your values.
# terraform.tfvars is gitignored — never commit real values.

# ----------------------------------------------------------------------------
# Required: GCP Project IDs
# ----------------------------------------------------------------------------

# Project where Cloud Build pipelines run
cicd_runner_project_id = "your-cicd-project-id"

# Project for staging resources (Cloud Run, Agent Engine, etc.)
staging_project_id = "your-staging-project-id"

# Project for production resources
prod_project_id = "your-prod-project-id"

# ----------------------------------------------------------------------------
# Required: GitHub repository details
# ----------------------------------------------------------------------------

repository_owner = "your-github-username-or-org"
repository_name  = "a2a-multiagent-ge-cicd"

# ----------------------------------------------------------------------------
# Optional: Region (default: us-central1)
# ----------------------------------------------------------------------------

# region = "us-central1"

# ----------------------------------------------------------------------------
# Optional: Cloud Build GitHub connection
# Set create_cb_connection = true on first run to create the connection.
# After it exists, set to false to avoid errors on re-apply.
# ----------------------------------------------------------------------------

# create_cb_connection       = true
# create_repository          = true
# host_connection_name       = "a2a-multiagent-ge-cicd-github-connection"
# github_app_installation_id = "123456789"
# github_pat_secret_id       = "github-pat-secret"

# ----------------------------------------------------------------------------
# Optional: Gemini Enterprise registration
# Leave empty to skip GE registration steps.
# ----------------------------------------------------------------------------

# ge_app_staging                  = "your-staging-ge-app-id"
# ge_app_prod                     = "your-prod-ge-app-id"
# auth_id_staging                 = "your-staging-oauth-client-id"
# auth_id_prod                    = "your-prod-oauth-client-id"
# oauth_client_id_secret_name     = "client-id-secret"
# oauth_client_secret_secret_name = "client-secret-secret"
